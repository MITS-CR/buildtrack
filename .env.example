# Azure Cosmos DB
COSMOS_ENDPOINT=https://YOUR_ACCOUNT.documents.azure.com:443/
COSMOS_KEY=YOUR_COSMOS_KEY
COSMOS_DATABASE=buildtrack
COSMOS_CONTAINER=media

# Azure Blob Storage
STORAGE_ACCOUNT_NAME=buildtrack
STORAGE_ACCOUNT_KEY=YOUR_STORAGE_KEY
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=buildtrack;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
STORAGE_CONTAINER_NAME=media

# Server
PORT=3000
NODE_ENV=production
